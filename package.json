{
  "name": "azure-pipelines-express-products",
  "version": "1.0.0",
  "description": "Express.js CRUD products API for Azure DevOps pipeline demos",
  "main": "src/index.js",
  "files": [
    "src"
  ],
  "scripts": {
    "start": "node src/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "express",
    "crud",
    "azure-pipelines",
    "demo"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://pkgs.dev.azure.com/CloudInnovateAzureOrg/_packaging/CloudInnovateAzureOrg/npm/registry/"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
